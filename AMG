    "# ==============================================================================\n",
    "# CELL 4: CHỐNG RÒ RỈ DỮ LIỆU (GROUP-K-FOLD) & CÂN BẰNG TẬP TRAIN (SMOTE)\n",
    "# ==============================================================================\n",
    "\n",
    "import numpy as np\n",
    "from sklearn.model_selection import GroupKFold\n",
    "from imblearn.over_sampling import SMOTE\n",
    "from torch_geometric.data import Data\n",
    "import torch\n",
    "\n",
    "def flatten_graph_data(data_list):\n",
    "    \"\"\" Ép phẳng các Node/Edge features của 5 dải tần thành vector 1D cho SMOTE. \"\"\"\n",
    "    X_flat, y_list = [], []\n",
    "    \n",
    "    for data in data_list:\n",
    "        features = []\n",
    "        for band in BANDS.keys():\n",
    "            # Kích thước Node (3x4=12), Edge (6) -> 18 đặc trưng mỗi dải tần -> Tổng 90\n",
    "            features.append(getattr(data, f'{band}_x').flatten().numpy())\n",
    "            features.append(getattr(data, f'{band}_edge_weight').flatten().numpy())\n",
    "        \n",
    "        X_flat.append(np.concatenate(features))\n",
    "        y_list.append(data.y.item())\n",
    "        \n",
    "    return np.array(X_flat), np.array(y_list)\n",
    "\n",
    "def unflatten_to_graph_data(X_flat, y_list, reference_data):\n",
    "    \"\"\" Khôi phục Vector 1D (đã SMOTE) về định dạng Custom PyG Data. \"\"\"\n",
    "    new_data_list = []\n",
    "    \n",
    "    for i in range(len(X_flat)):\n",
    "        row = X_flat[i]\n",
    "        label = y_list[i]\n",
    "        \n",
    "        # --- ĐIỂM FIX LỖI CRITICAL TẠI ĐÂY ---\n",
    "        # Bắt buộc phải có num_nodes=NUM_CHANNELS (3) để PyG DataLoader biết cách nối batch\n",
    "        data = Data(y=torch.tensor([label], dtype=torch.long), num_nodes=NUM_CHANNELS)\n",
    "        data.sub_id = \"SMOTE_SYNTHETIC\" # Đánh dấu là dữ liệu sinh ra\n",
    "        \n",
    "        ptr = 0\n",
    "        for band in BANDS.keys():\n",
    "            # Khôi phục Node features (3, 4)\n",
    "            node_size = NUM_CHANNELS * 4\n",
    "            node_vals = row[ptr : ptr + node_size].reshape(NUM_CHANNELS, 4)\n",
    "            setattr(data, f'{band}_x', torch.tensor(node_vals, dtype=torch.float))\n",
    "            ptr += node_size\n",
    "            \n",
    "            # Khôi phục Edge weights (6 cạnh)\n",
    "            edge_size = NUM_CHANNELS * (NUM_CHANNELS - 1)\n",
    "            edge_vals = row[ptr : ptr + edge_size]\n",
    "            setattr(data, f'{band}_edge_weight', torch.tensor(edge_vals, dtype=torch.float))\n",
    "            \n",
    "            # Copy nguyên si cấu trúc kết nối edge_index\n",
    "            setattr(data, f'{band}_edge_index', getattr(reference_data, f'{band}_edge_index').clone())\n",
    "            ptr += edge_size\n",
    "            \n",
    "        new_data_list.append(data)\n",
    "        \n",
    "    return new_data_list\n",
    "\n",
    "def generate_folds(full_dataset, n_splits=5):\n",
    "    \"\"\"\n",
    "    Hàm sinh 5-Folds tuân thủ nghiêm ngặt nguyên tắc:\n",
    "    1. GroupKFold theo Subject_ID.\n",
    "    2. Chỉ SMOTE trên tập Train.\n",
    "    \"\"\"\n",
    "    sub_ids = [data.sub_id for data in full_dataset]\n",
    "    labels = [data.y.item() for data in full_dataset]\n",
    "    \n",
    "    gkf = GroupKFold(n_splits=n_splits)\n",
    "    folds_data = []\n",
    "    \n",
    "    for fold, (train_idx, val_idx) in enumerate(gkf.split(full_dataset, labels, groups=sub_ids)):\n",
    "        print(f\"\\n--- Đang xử lý Fold {fold + 1}/{n_splits} ---\")\n",
    "        \n",
    "        train_data = [full_dataset[i] for i in train_idx]\n",
    "        val_data = [full_dataset[i] for i in val_idx]\n",
    "        \n",
    "        print(f\"Kích thước Train gốc: {len(train_data)} | Validation gốc: {len(val_data)}\")\n",
    "        \n",
    "        X_train_flat, y_train_flat = flatten_graph_data(train_data)\n",
    "        \n",
    "        smote = SMOTE(random_state=42)\n",
    "        X_train_resampled, y_train_resampled = smote.fit_resample(X_train_flat, y_train_flat)\n",
    "        \n",
    "        train_data_smote = unflatten_to_graph_data(X_train_resampled, y_train_resampled, reference_data=train_data[0])\n",
    "        print(f\"Kích thước Train sau SMOTE: {len(train_data_smote)} (Cân bằng 3 class)\")\n",
    "        \n",
    "        folds_data.append({\n",
    "            'train': train_data_smote,\n",
    "            'val': val_data \n",
    "        })\n",
    "        \n",
    "    return folds_data\n",
    "\n",
    "print(\"✅ Đã cập nhật Cell 4: Fix lỗi Batching SMOTE Data.\")"
   ]
