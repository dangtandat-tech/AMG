    "# ==============================================================================\n",
    "# CELL 3: TIỀN XỬ LÝ MNE & ĐÓNG GÓI PYG DATA (MULTI-GRANULARITY)\n",
    "# ==============================================================================\n",
    "\n",
    "import torch\n",
    "from torch_geometric.data import Data\n",
    "from tqdm import tqdm\n",
    "\n",
    "def process_and_package_epoch(epoch_data, sfreq, label, sub_id):\n",
    "    \"\"\"\n",
    "    Xử lý 1 Epoch: Lọc 5 dải tần, tính toán Node/Edge features, đóng gói thành PyG Data.\n",
    "    Input: (3 channels, 2500 samples)\n",
    "    Output: Đối tượng PyG Data chứa 5 tập hợp (x, edge_index, edge_weight)\n",
    "    \"\"\"\n",
    "    # Kẹp biên độ để loại bỏ nhiễu đột biến\n",
    "    epoch_data = np.clip(epoch_data, -CLIP_UV, CLIP_UV)\n",
    "    \n",
    "    band_tensors = {}\n",
    "    \n",
    "    for band_name, (fmin, fmax) in BANDS.items():\n",
    "        # Lọc tín hiệu cho dải tần hiện tại\n",
    "        filtered_signal = apply_bandpass_filter(epoch_data, sfreq, fmin, fmax)\n",
    "        \n",
    "        # Tính Đặc trưng nút: Ma trận (3, 4)\n",
    "        node_feats = calculate_de_hjorth(filtered_signal, sfreq)\n",
    "        \n",
    "        # Tính Trọng số cạnh (PLI): Ma trận (3, 3)\n",
    "        pli_adj = calculate_pli_matrix(filtered_signal)\n",
    "        \n",
    "        # Chuyển đổi Ma trận kề thành edge_index và edge_weight của PyG\n",
    "        edge_index, edge_weight = [], []\n",
    "        for i in range(NUM_CHANNELS):\n",
    "            for j in range(NUM_CHANNELS):\n",
    "                if i != j: # Loại bỏ self-loop (đường chéo)\n",
    "                    edge_index.append([i, j])\n",
    "                    edge_weight.append(pli_adj[i, j])\n",
    "                    \n",
    "        # Lưu vào dict tạm thời\n",
    "        band_tensors[f'{band_name}_x'] = torch.tensor(node_feats, dtype=torch.float)\n",
    "        band_tensors[f'{band_name}_edge_index'] = torch.tensor(edge_index, dtype=torch.long).t().contiguous()\n",
    "        band_tensors[f'{band_name}_edge_weight'] = torch.tensor(edge_weight, dtype=torch.float)\n",
    "\n",
    "    # Đóng gói tất cả vào 1 object Data duy nhất\n",
    "    data = Data(y=torch.tensor([label], dtype=torch.long), num_nodes=NUM_CHANNELS)\n",
    "    data.sub_id = sub_id # Gắn Subject ID để chia Fold an toàn\n",
    "    \n",
    "    for k, v in band_tensors.items():\n",
    "        setattr(data, k, v)\n",
    "        \n",
    "    return data\n",
    "\n",
    "def process_subject_mne(file_path, sub_id, label):\n",
    "    \"\"\"\n",
    "    Đọc file EDF/SET, lọc Notch/Bandpass chung, cắt Epoch và gọi hàm đóng gói.\n",
    "    \"\"\"\n",
    "    try:\n",
    "        raw = mne.io.read_raw(file_path, preload=True, verbose=False)\n",
    "        available_chans = raw.info['ch_names']\n",
    "        \n",
    "        # Kiểm tra kênh T3, P3, O1\n",
    "        if not all(ch in available_chans for ch in TARGET_CHANNELS):\n",
    "            return []\n",
    "            \n",
    "        raw.pick_channels(TARGET_CHANNELS, ordered=True)\n",
    "        raw.set_eeg_reference('average', projection=False, verbose=False) # CAR\n",
    "        \n",
    "        # Cắt lấy 5 phút đầu tiên\n",
    "        if raw.times[-1] > DURATION_LIMIT:\n",
    "            raw.crop(tmin=0, tmax=DURATION_LIMIT)\n",
    "            \n",
    "        # Lọc Notch 50Hz và Bandpass 0.5-45Hz\n",
    "        raw.notch_filter(freqs=NOTCH_FREQ, verbose=False)\n",
    "        raw.filter(l_freq=0.5, h_freq=45.0, method='iir', verbose=False)\n",
    "        \n",
    "        sfreq = raw.info['sfreq']\n",
    "        data = raw.get_data()\n",
    "        \n",
    "        # Thông số Sliding Window\n",
    "        window_samples = int(WINDOW_SIZE * sfreq)\n",
    "        step_samples = int(window_samples * (1 - OVERLAP))\n",
    "        total_samples = data.shape[1]\n",
    "        \n",
    "        dataset_list = []\n",
    "        for start in range(0, total_samples - window_samples + 1, step_samples):\n",
    "            end = start + window_samples\n",
    "            epoch_data = data[:, start:end]\n",
    "            \n",
    "            # Đóng gói và lưu lại\n",
    "            graph_data = process_and_package_epoch(epoch_data, sfreq, label, sub_id)\n",
    "            dataset_list.append(graph_data)\n",
    "            \n",
    "        return dataset_list\n",
    "        \n",
    "    except Exception as e:\n",
    "        print(f\"Lỗi xử lý {sub_id}: {str(e)}\")\n",
    "        return []\n",
