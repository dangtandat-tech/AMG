    "# ==============================================================================\n",
    "# CELL 2: LÕI THUẬT TOÁN TRÍCH XUẤT ĐẶC TRƯNG & TRỌNG SỐ ĐỒ THỊ\n",
    "# ==============================================================================\n",
    "\n",
    "def apply_bandpass_filter(data, sfreq, fmin, fmax):\n",
    "    \"\"\"\n",
    "    Lọc tín hiệu theo dải tần con bằng bộ lọc Butterworth (IIR).\n",
    "    Input: (n_channels, n_samples)\n",
    "    Output: (n_channels, n_samples)\n",
    "    \"\"\"\n",
    "    sos = butter(4, [fmin, fmax], btype='bandpass', fs=sfreq, output='sos')\n",
    "    return sosfiltfilt(sos, data, axis=1)\n",
    "\n",
    "def calculate_de_hjorth(segment, sfreq):\n",
    "    \"\"\"\n",
    "    Tính Differential Entropy (DE) và Hjorth (Activity, Mobility, Complexity)\n",
    "    cho MỘT dải tần cụ thể.\n",
    "    Input: (3, n_samples) - 3 kênh EEG\n",
    "    Output: (3, 4) - Ma trận Nút chứa 4 features cho mỗi kênh.\n",
    "    \"\"\"\n",
    "    eps = 1e-10\n",
    "    n_channels = segment.shape[0]\n",
    "    features = np.zeros((n_channels, 4))\n",
    "    \n",
    "    # Tính toán Phương sai (Variance / Band Power / Activity)\n",
    "    activity = np.var(segment, axis=1)\n",
    "    \n",
    "    # 1. Differential Entropy (DE)\n",
    "    # DE = 0.5 * log2(2 * pi * e * variance)\n",
    "    factor = 2 * np.pi * np.e\n",
    "    safe_activity = np.maximum(activity, eps)\n",
    "    de = 0.5 * np.log2(factor * safe_activity)\n",
    "    \n",
    "    # Tính đạo hàm bậc 1 và 2 dọc theo trục thời gian cho Hjorth\n",
    "    dx = np.diff(segment, axis=1)\n",
    "    ddx = np.diff(dx, axis=1)\n",
    "    \n",
    "    # Tính phương sai các đạo hàm\n",
    "    var_dx = np.var(dx, axis=1)\n",
    "    var_ddx = np.var(ddx, axis=1)\n",
    "    \n",
    "    # 2. Hjorth Mobility\n",
    "    mobility = np.sqrt(var_dx / safe_activity)\n",
    "    \n",
    "    # 3. Hjorth Complexity\n",
    "    mobility_dx = np.sqrt(var_ddx / np.maximum(var_dx, eps))\n",
    "    complexity = mobility_dx / np.maximum(mobility, eps)\n",
    "    \n",
    "    # Lắp ráp thành ma trận (3 kênh x 4 đặc trưng)\n",
    "    features[:, 0] = np.clip(de, -50.0, 50.0) # Clip DE để tránh Gradient vỡ\n",
    "    features[:, 1] = activity\n",
    "    features[:, 2] = mobility\n",
    "    features[:, 3] = complexity\n",
    "    \n",
    "    return features\n",
    "\n",
    "def calculate_pli_matrix(segment):\n",
    "    \"\"\"\n",
    "    Tính trọng số liên kết (Edge Weights) bằng Phase Lag Index (PLI).\n",
    "    Sử dụng Biến đổi Hilbert để lấy pha tức thời.\n",
    "    Input: (3, n_samples)\n",
    "    Output: (3, 3) - Ma trận Kề (Adjacency Matrix) đại diện đồ thị, đường chéo = 0.\n",
    "    \"\"\"\n",
    "    n_channels = segment.shape[0]\n",
    "    pli_matrix = np.zeros((n_channels, n_channels))\n",
    "    \n",
    "    # Lấy pha tức thời bằng Hilbert Transform\n",
    "    analytic_signal = hilbert(segment, axis=1)\n",
    "    instantaneous_phase = np.angle(analytic_signal)\n",
    "    \n",
    "    # Tính PLI giữa từng cặp kênh\n",
    "    for i in range(n_channels):\n",
    "        for j in range(i + 1, n_channels):\n",
    "            phase_diff = instantaneous_phase[i] - instantaneous_phase[j]\n",
    "            # Công thức PLI = |mean(sign(sin(delta_phase)))|\n",
    "            pli_val = np.abs(np.mean(np.sign(np.sin(phase_diff))))\n",
    "            \n",
    "            # Gán đối xứng (Đồ thị vô hướng)\n",
    "            pli_matrix[i, j] = pli_val\n",
    "            pli_matrix[j, i] = pli_val\n",
    "            \n",
    "    return pli_matrix\n",
    "\n",
    "print(\"✅ Hàm lõi: Bandpass Filter, DE, Hjorth và PLI Matrix đã được biên dịch.\")"
   ]
