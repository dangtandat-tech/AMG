    "# ==============================================================================\n",
    "# CELL 6: TRAINING LOOP VÀ ĐÁNH GIÁ (EVALUATION METRICS)\n",
    "# ==============================================================================\n",
    "\n",
    "import torch.optim as optim\n",
    "from torch_geometric.loader import DataLoader\n",
    "from sklearn.metrics import precision_score, recall_score, f1_score, confusion_matrix\n",
    "import warnings\n",
    "\n",
    "def train_and_evaluate_fold(fold_data, fold_idx, num_epochs=50, batch_size=32, device='cuda'):\n",
    "    \"\"\"\n",
    "    Huấn luyện mô hình trên 1 Fold.\n",
    "    fold_data chứa dict: {'train': [Data, ...], 'val': [Data, ...]}\n",
    "    \"\"\"\n",
    "    print(f\"\\n🚀 BẮT ĐẦU TRAINING FOLD {fold_idx + 1}\")\n",
    "    \n",
    "    # Chuẩn bị Dataloader\n",
    "    train_loader = DataLoader(fold_data['train'], batch_size=batch_size, shuffle=True)\n",
    "    val_loader = DataLoader(fold_data['val'], batch_size=batch_size, shuffle=False)\n",
    "    \n",
    "    # Khởi tạo Mô hình, Loss, Optimizer\n",
    "    model = MultiGranularityGraphTransformer(num_classes=3).to(device)\n",
    "    criterion = FocalLoss(gamma=2.0)\n",
    "    optimizer = torch.optim.AdamW(model.parameters(), lr=1e-3, weight_decay=1e-2) \n",
    "    scheduler = optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=num_epochs)\n",
    "    \n",
    "    best_val_f1 = 0.0\n",
    "    best_metrics = {}\n",
    "    \n",
    "    for epoch in range(num_epochs):\n",
    "        # === TRAIN PHASE ===\n",
    "        model.train()\n",
    "        train_loss = 0.0\n",
    "        for data in train_loader:\n",
    "            data = data.to(device)\n",
    "            optimizer.zero_grad()\n",
    "            \n",
    "            out = model(data)\n",
    "            loss = criterion(out, data.y.view(-1))\n",
    "            \n",
    "            loss.backward()\n",
    "            torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)\n",
    "            optimizer.step()\n",
    "            train_loss += loss.item() * data.num_graphs\n",
    "            \n",
    "        scheduler.step()\n",
    "        train_loss /= len(train_loader.dataset)\n",
    "        \n",
    "        # === VALIDATION PHASE ===\n",
    "        model.eval()\n",
    "        val_loss = 0.0\n",
    "        all_preds = []\n",
    "        all_trues = []\n",
    "        \n",
    "        with torch.no_grad():\n",
    "            for data in val_loader:\n",
    "                data = data.to(device)\n",
    "                out = model(data)\n",
    "                loss = criterion(out, data.y.view(-1))\n",
    "                val_loss += loss.item() * data.num_graphs\n",
    "                \n",
    "                preds = out.argmax(dim=1)\n",
    "                all_preds.extend(preds.cpu().numpy())\n",
    "                all_trues.extend(data.y.cpu().numpy())\n",
    "                \n",
    "        val_loss /= len(val_loader.dataset)\n",
    "        \n",
    "        # Tính toán Metrics (Macro average cho 3 class)\n",
    "        with warnings.catch_warnings():\n",
    "            warnings.simplefilter(\"ignore\") # Bỏ qua cảnh báo zero_division nếu có\n",
    "            macro_f1 = f1_score(all_trues, all_preds, average='macro')\n",
    "            macro_prec = precision_score(all_trues, all_preds, average='macro')\n",
    "            macro_rec = recall_score(all_trues, all_preds, average='macro')\n",
    "        \n",
    "        # Lưu lại model tốt nhất dựa trên Validation F1\n",
    "        if macro_f1 > best_val_f1:\n",
    "            best_val_f1 = macro_f1\n",
    "            best_metrics = {\n",
    "                'loss': val_loss,\n",
    "                'f1': macro_f1,\n",
    "                'precision': macro_prec,\n",
    "                'recall': macro_rec,\n",
    "                'cm': confusion_matrix(all_trues, all_preds, labels=[0, 1, 2])\n",
    "            }\n",
    "            \n",
