    "# ==============================================================================\n",
    "# CELL 1: KHAI BÁO THƯ VIỆN & CẤU HÌNH SIÊU THAM SỐ (HYPERPARAMETERS)\n",
    "# ==============================================================================\n",
    "\n",
    "import os\n",
    "import glob\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import mne\n",
    "import warnings\n",
    "from scipy.signal import butter, sosfiltfilt, hilbert\n",
    "import torch\n",
    "\n",
    "# Tắt cảnh báo MNE để làm sạch log Kaggle\n",
    "warnings.filterwarnings(\"ignore\")\n",
    "mne.set_log_level('ERROR')\n",
    "\n",
    "# 1. CẤU HÌNH TÍN HIỆU LÂM SÀNG (TUÂN THỦ TUYỆT ĐỐI BLUEPRINT)\n",
    "TARGET_CHANNELS = ['T3', 'P3', 'O1']\n",
    "NUM_CHANNELS = len(TARGET_CHANNELS)\n",
    "\n",
    "# Dải tần số (5 Bands Multi-Granularity)\n",
    "BANDS = {\n",
    "    'Delta': (0.5, 4.0),\n",
    "    'Theta': (4.0, 8.0),\n",
    "    'Alpha': (8.0, 13.0),\n",
    "    'Beta': (13.0, 30.0),   # Blueprint quy định Beta: 13 - 30 Hz\n",
    "    'Gamma': (30.0, 45.0)   # Blueprint quy định Gamma: 30 - 45 Hz\n",
    "}\n",
    "NUM_BANDS = len(BANDS)\n",
    "\n",
    "# 2. CẤU HÌNH EPOCH & TIỀN XỬ LÝ\n",
    "WINDOW_SIZE = 10      # Cửa sổ 10 giây\n",
    "OVERLAP = 0.9         # Trượt 1 giây (Overlap 90%)\n",
    "DURATION_LIMIT = 300  # Lấy 300s (5 phút) đầu tiên\n",
    "CLIP_UV = 250e-6      # Kẹp biên độ tín hiệu ±250 μV\n",
    "NOTCH_FREQ = 50.0     # Lọc Notch 50Hz (chuẩn điện lưới)\n",
    "\n",
    "# 3. NHÃN PHÂN LOẠI (3 CLASS)\n",
    "LABEL_MAP = {\n",
    "    'HC': 0,\n",
    "    'MCI': 1,\n",
    "    'AD': 2\n",
    "}\n",
    "\n",
    "print(f\"✅ Khởi tạo thành công: {NUM_CHANNELS} Kênh | {NUM_BANDS} Dải tần | Lớp bài toán: 3 Classes.\")"
   ]
