    "# ==============================================================================\n",
    "# CELL 5: XÂY DỰNG KIẾN TRÚC MÔ HÌNH (PYTORCH GEOMETRIC)\n",
    "# ==============================================================================\n",
    "\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "from torch_geometric.nn import TransformerConv, global_mean_pool, global_max_pool\n",
    "\n",
    "class FrequencyBranch(nn.Module):\n",
    "    \"\"\"\n",
    "    Nhánh xử lý độc lập cho MỘT dải tần số.\n",
    "    \"\"\"\n",
    "    def __init__(self, in_channels=4):\n",
    "        super(FrequencyBranch, self).__init__()\n",
    "        # Input: (Batch * 3 nodes, in_channels)\n",
    "        # Lớp 1: TransformerConv (out=16, heads=2 -> concat=32)\n",
    "        self.conv1 = TransformerConv(in_channels=in_channels, out_channels=16, heads=2, edge_dim=1, concat=True)\n",
    "        self.bn1 = nn.BatchNorm1d(32)\n",
    "        \n",
    "        # Lớp 2: TransformerConv (in=32, out=32, heads=1)\n",
    "        self.conv2 = TransformerConv(in_channels=32, out_channels=32, heads=1, edge_dim=1, concat=True)\n",
    "        self.bn2 = nn.BatchNorm1d(32)\n",
    "\n",
    "    def forward(self, x, edge_index, edge_weight, batch):\n",
    "        # Trọng số cạnh cần reshape để phù hợp với edge_dim=1\n",
    "        edge_weight = edge_weight.view(-1, 1)\n",
    "        \n",
    "        # Conv Block 1\n",
    "        x = self.conv1(x, edge_index, edge_weight)\n",
    "        x = self.bn1(x)\n",
    "        x = F.leaky_relu(x)\n",
    "        x = F.dropout(x, p=0.4, training=self.training)\n",
    "        \n",
    "        # Conv Block 2\n",
    "        x = self.conv2(x, edge_index, edge_weight)\n",
    "        x = self.bn2(x)\n",
    "        x = F.leaky_relu(x)\n",
    "        x = F.dropout(x, p=0.4, training=self.training)\n",
    "        \n",
    "        # Pooling Block (Kết hợp Mean và Max)\n",
    "        # Input pooling: (Batch * 3 nodes, 32)\n",
    "        mean_pool = global_mean_pool(x, batch) # -> (Batch, 32)\n",
    "        max_pool = global_max_pool(x, batch)   # -> (Batch, 32)\n",
    "        \n",
    "        # Ghép nối Pooling -> Đầu ra của 1 nhánh: (Batch, 64)\n",
    "        out = torch.cat([mean_pool, max_pool], dim=1)\n",
    "        return out\n",
    "\n",
    "class MultiGranularityGraphTransformer(nn.Module):\n",
    "    \"\"\"\n",
    "    Mô hình chính: Chạy song song 5 nhánh dải tần và dung hợp (Fusion).\n",
    "    \"\"\"\n",
    "    def __init__(self, num_classes=3):\n",
    "        super(MultiGranularityGraphTransformer, self).__init__()\n",
    "        \n",
    "        # 5 nhánh chạy song song cho 5 dải tần\n",
    "        self.branch_delta = FrequencyBranch(in_channels=4)\n",
    "        self.branch_theta = FrequencyBranch(in_channels=4)\n",
    "        self.branch_alpha = FrequencyBranch(in_channels=4)\n",
    "        self.branch_beta  = FrequencyBranch(in_channels=4)\n",
    "        self.branch_gamma = FrequencyBranch(in_channels=4)\n",
    "        \n",
    "        # Khối Dung hợp (Fusion Block) & Phân loại (Classification Head)\n",
    "        # Đầu vào FC: 64 * 5 nhánh = 320\n",
    "        self.fc1 = nn.Linear(320, 128)\n",
    "        self.bn_fc1 = nn.BatchNorm1d(128)\n",
    "        self.dropout = nn.Dropout(0.5)\n",
    "        \n",
    "        self.fc2 = nn.Linear(128, 64)\n",
    "        self.fc3 = nn.Linear(64, num_classes)\n",
    "\n",
    "    def forward(self, data):\n",
    "        # Lấy thông tin batch mask (để biết node nào thuộc đồ thị nào trong batch)\n",
    "        batch = data.batch\n",
    "        \n",
    "        # Chạy 5 nhánh song song\n",
    "        # Output mỗi nhánh: (Batch, 64)\n",
    "        out_delta = self.branch_delta(data.Delta_x, data.Delta_edge_index, data.Delta_edge_weight, batch)\n",
    "        out_theta = self.branch_theta(data.Theta_x, data.Theta_edge_index, data.Theta_edge_weight, batch)\n",
    "        out_alpha = self.branch_alpha(data.Alpha_x, data.Alpha_edge_index, data.Alpha_edge_weight, batch)\n",
    "        out_beta  = self.branch_beta(data.Beta_x,  data.Beta_edge_index,  data.Beta_edge_weight,  batch)\n",
    "        out_gamma = self.branch_gamma(data.Gamma_x, data.Gamma_edge_index, data.Gamma_edge_weight, batch)\n",
    "        \n",
    "        # Concatenate 5 nhánh -> (Batch, 320)\n",
    "        fused = torch.cat([out_delta, out_theta, out_alpha, out_beta, out_gamma], dim=1)\n",
    "        \n",
    "        # Fully Connected Block\n",
    "        x = self.fc1(fused)\n",
    "        x = self.bn_fc1(x)\n",
    "        x = F.leaky_relu(x)\n",
    "        x = self.dropout(x)\n",
    "        \n",
    "        x = self.fc2(x)\n",
    "        x = F.leaky_relu(x)\n",
    "        \n",
    "        # Output Logits: (Batch, 3)\n",
    "        out = self.fc3(x)\n",
    "        return out\n",
    "\n",
    "print(\"✅ Đã khởi tạo Kiến trúc Multi-Granularity Graph Transformer.\")"
   ]
