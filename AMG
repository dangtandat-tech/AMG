    "def main_pipeline():\n",
    "    # 1. ĐƯỜNG DẪN DỮ LIỆU\n",
    "    RAW_DATA_ROOT = '/kaggle/input/datasets/dtandat/mf-mgcn-datasets/ds004504'\n",
    "    tsv_path = os.path.join(RAW_DATA_ROOT, 'participants.tsv')\n",
    "    \n",
    "    if not os.path.exists(RAW_DATA_ROOT):\n",
    "        print(f\"❌ LỖI: Không tìm thấy thư mục dataset tại {RAW_DATA_ROOT}\")\n",
    "        return\n",
    "\n",
    "    # 2. ĐỌC NHÃN TỪ PARTICIPANTS.TSV\n",
    "    print(\"🔍 Đang đọc thông tin nhãn từ participants.tsv...\")\n",
    "    try:\n",
    "        # Thử đọc bằng tab\n",
    "        df = pd.read_csv(tsv_path, sep='\\t')\n",
    "    except:\n",
    "        # Nếu lỗi, thử đọc bằng regex khoảng trắng\n",
    "        df = pd.read_csv(tsv_path, sep=r'\\s+')\n",
    "        \n",
    "    sub_label_map = {}\n",
    "    for _, row in df.iterrows():\n",
    "        sub = row['participant_id']\n",
    "        grp = str(row['Group']).strip()\n",
    "        \n",
    "        # Ánh xạ 3 class (NC: 0, MCI: 1, AD: 2)\n",
    "        if grp == 'A':\n",
    "            sub_label_map[sub] = 2  # Alzheimer's Disease\n",
    "        elif grp == 'C':\n",
    "            sub_label_map[sub] = 0  # Normal Control / Healthy\n",
    "        elif grp == 'F' or grp == 'MCI': \n",
    "            sub_label_map[sub] = 1  # Mild Cognitive Impairment (hoặc FTD)\n",
    "            \n",
    "    print(f\"✅ Đã ánh xạ nhãn thành công cho {len(sub_label_map)} subjects.\")\n",
    "\n",
    "    # 3. TRÍCH XUẤT ĐẶC TRƯNG ĐỒ THỊ\n",
    "    print(\"\\n🔍 Bắt đầu trích xuất Multi-Granularity Graph...\")\n",
    "    full_graph_dataset = []\n",
    "    \n",
    "    sub_folders = [f for f in os.listdir(RAW_DATA_ROOT) if f.startswith('sub-')]\n",
    "    sub_folders.sort()\n",
    "    \n",
    "    for sub_id in sub_folders:\n",
    "        if sub_id not in sub_label_map:\n",
    "            continue # Bỏ qua subject không có trong file TSV hoặc nhãn không hợp lệ\n",
    "            \n",
    "        label = sub_label_map[sub_id]\n",
    "        eeg_path = os.path.join(RAW_DATA_ROOT, sub_id, 'eeg')\n",
    "        set_files = glob.glob(os.path.join(eeg_path, \"*.set\")) # Đọc file .set\n",
    "        \n",
    "        if set_files:\n",
    "            # Truyền nhãn và id xuống hàm xử lý\n",
    "            sub_graphs = process_subject_mne(set_files[0], sub_id, label)\n",
    "            if sub_graphs:\n",
    "                full_graph_dataset.extend(sub_graphs)\n",
    "                print(f\"  + {sub_id} (Label {label}): Trích xuất được {len(sub_graphs)} epochs.\")\n",
    "        else:\n",
    "            print(f\"  - Bỏ qua {sub_id}: Không tìm thấy file EEG (.set)\")\n",
    "\n",
    "    total_epochs = len(full_graph_dataset)\n",
    "    print(f\"\\n✅ ĐÃ TRÍCH XUẤT XONG. Tổng số Epochs thu được: {total_epochs}\")\n",
    "    \n",
    "    if total_epochs == 0:\n",
    "        print(\"❌ Dừng chạy vì Dataset trống (Hãy kiểm tra lại đường dẫn/tên file).\")\n",
    "        return\n",
    "\n",
    "    # 4. CHIA FOLD VÀ XỬ LÝ SMOTE\n",
    "    print(\"\\n🔄 BẮT ĐẦU CHIA FOLD & SMOTE (GROUP-K-FOLD CHỐNG DATA LEAKAGE)...\")\n",
    "    folds_data = generate_folds(full_graph_dataset, n_splits=5)\n",
    "    \n",
    "    # 5. TRAINING LOOP CHO 5 FOLDS\n",
    "    print(\"\\n⚡ BẮT ĐẦU HUẤN LUYỆN MÔ HÌNH MULTI-GRANULARITY GRAPH TRANSFORMER...\")\n",
    "    device = 'cuda' if torch.cuda.is_available() else 'cpu'\n",
    "    print(f\"Thiết bị đang sử dụng: {device}\")\n",
    "    \n",
    "    all_metrics = []\n",
    "    \n",
    "    for fold_idx, fold_data in enumerate(folds_data):\n",
    "        # Chạy Training cho từng Fold\n",
    "        metrics = train_and_evaluate_fold(\n",
    "            fold_data, \n",
    "            fold_idx, \n",
    "            num_epochs=50, \n",
    "            batch_size=32, \n",
    "            device=device\n",
    "        )\n",
    "        all_metrics.append(metrics)\n",
    "        \n",
    "    # 6. TỔNG HỢP VÀ BÁO CÁO KẾT QUẢ\n",
    "    print(\"\\n\" + \"=\"*60)\n",
    "    print(\"🏆 BÁO CÁO KẾT QUẢ TỔNG THỂ (5-FOLD CROSS VALIDATION) 🏆\")\n",
    "    print(\"=\"*60)\n",
    "    \n",
    "    avg_f1 = np.mean([m['f1'] for m in all_metrics])\n",
    "    avg_prec = np.mean([m['precision'] for m in all_metrics])\n",
    "    avg_rec = np.mean([m['recall'] for m in all_metrics])\n",
    "    \n",
