    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "\n",
    "class FocalLoss(nn.Module):\n",
    "    def __init__(self, gamma=2.0, alpha=None, reduction='mean'):\n",
    "        \"\"\"\n",
    "        Focal Loss cho bài toán phân loại nhiều lớp (Multi-class).\n",
    "        \n",
    "        Args:\n",
    "            gamma (float): Thông số tập trung. gamma càng lớn, mô hình càng chú ý vào mẫu dự đoán sai.\n",
    "            alpha (Tensor, optional): Trọng số cho từng class để xử lý mất cân bằng. Định dạng: 1D Tensor.\n",
    "            reduction (str): 'mean', 'sum', hoặc 'none'.\n",
    "        \"\"\"\n",
    "        super(FocalLoss, self).__init__()\n",
    "        self.gamma = gamma\n",
    "        self.alpha = alpha \n",
    "        self.reduction = reduction\n",
    "\n",
    "    def forward(self, inputs, targets):\n",
    "        # inputs: Logits đầu ra từ mô hình (chưa qua Softmax), shape [batch_size, num_classes]\n",
    "        # targets: Nhãn thực tế (class index), shape [batch_size]\n",
    "        \n",
    "        # 1. Tính xác suất p bằng Softmax\n",
    "        log_probs = F.log_softmax(inputs, dim=-1)\n",
    "        probs = torch.exp(log_probs)\n",
    "        \n",
    "        # 2. Lấy xác suất dự đoán của class ĐÚNG (p_t)\n",
    "        pt = probs.gather(1, targets.unsqueeze(1)).squeeze(1)\n",
    "        log_pt = log_probs.gather(1, targets.unsqueeze(1)).squeeze(1)\n",
    "        \n",
    "        # 3. Tính Focal Loss cốt lõi: -(1 - pt)^gamma * log(pt)\n",
    "        focal_loss = -((1 - pt) ** self.gamma) * log_pt\n",
    "        \n",
    "        # 4. Áp dụng trọng số Alpha cho từng class (nếu có truyền vào)\n",
    "        if self.alpha is not None:\n",
    "            # Đẩy alpha vào cùng device với targets (CPU/GPU)\n",
    "            self.alpha = self.alpha.to(targets.device)\n",
    "            alpha_t = self.alpha.gather(0, targets)\n",
    "            focal_loss = focal_loss * alpha_t\n",
    "            \n",
    "        # 5. Reduction\n",
    "        if self.reduction == 'mean':\n",
    "            return focal_loss.mean()\n",
    "        elif self.reduction == 'sum':\n",
    "            return focal_loss.sum()\n",
    "        else:\n",
    "            return focal_loss"
